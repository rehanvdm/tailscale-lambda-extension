    "@stylistic/eslint-plugin": "^2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "aws-cdk-lib": "2.225.0",
    "commit-and-tag-version": "^12",
    "constructs": "10.5.1",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^3.10.1",
